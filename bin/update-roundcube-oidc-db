#!/usr/bin/env php
<?php

declare(strict_types=1);

$scriptPath = realpath((string) ($_SERVER['SCRIPT_FILENAME'] ?? __FILE__));
$scriptDirectory = $scriptPath === false ? __DIR__ : dirname($scriptPath);
$roundcubeRoot = realpath($scriptDirectory . '/../../..');
if ($roundcubeRoot === false) {
    fwrite(STDERR, "Unable to locate the Roundcube installation\n");
    exit(1);
}

$schemaDirectory = dirname($scriptDirectory) . '/SQL';
require_once $scriptDirectory . '/update-roundcube-oidc-db.php';

sizestation_update_roundcube_oidc_db($roundcubeRoot, $schemaDirectory);
