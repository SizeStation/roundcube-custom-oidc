#!/usr/bin/env bash

set -Eeuo pipefail

VERSION="${ROUNDCUBE_OIDC_ADMIN_VERSION:-1.0.0-rc.15}"
IMAGE="${ROUNDCUBE_OIDC_ADMIN_IMAGE:-roundcube/roundcubemail:1.7.x-apache}"
ISSUER="${ROUNDCUBE_OIDC_ISSUER:-https://auth.sizestation.com/application/o/roundcube/}"
OPENBAO_ADDRESS="${ROUNDCUBE_OPENBAO_ADDRESS:-https://bao.sizestation.cloud}"
TOKEN_FILE="${ROUNDCUBE_OIDC_PROVISIONING_TOKEN_FILE:-/root/.secrets/openbao-provisioning-token}"
APPROLE_ID="${ROUNDCUBE_OPENBAO_APPROLE_ID:-}"
APPROLE_SECRET="${ROUNDCUBE_OPENBAO_APPROLE_SECRET:-}"
APPROLE_MOUNT="${ROUNDCUBE_OPENBAO_APPROLE_MOUNT:-approle}"
DB_VOLUME="${ROUNDCUBE_OIDC_DB_VOLUME:-roundcube_db}"
SECRETS_VOLUME="${ROUNDCUBE_OIDC_SECRETS_VOLUME:-roundcube_bao_files}"
NETWORK="${ROUNDCUBE_OIDC_NETWORK:-public}"
FORMAT="${ROUNDCUBE_OIDC_ADMIN_FORMAT:-human}"

usage() {
    cat <<'USAGE'
Roundcube OIDC mailbox administration

Usage:
  roundcube-oidc-admin [--dry-run] provision SUB MAILBOX [LABEL]
  roundcube-oidc-admin [--dry-run] add-email SUB MAILBOX [LABEL]
  roundcube-oidc-admin users
  roundcube-oidc-admin user PRINCIPAL_ID
  roundcube-oidc-admin emails [PRINCIPAL_ID]
  roundcube-oidc-admin email ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] rotate ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] validate ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] prefer ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] clear-preferred ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] enable-email ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] disable-email ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] remove-email ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] purge-email ASSIGNMENT_ID
  roundcube-oidc-admin [--dry-run] enable-user PRINCIPAL_ID
  roundcube-oidc-admin [--dry-run] disable-user PRINCIPAL_ID
  roundcube-oidc-admin [--dry-run] reconcile-user PRINCIPAL_ID
  roundcube-oidc-admin [--dry-run] reconcile-all
  roundcube-oidc-admin audit [PRINCIPAL_ID]
  roundcube-oidc-admin raw CLI_ARGUMENTS...

The provision command creates the permanent anchor mailbox. add-email adds a
secondary mailbox. Passwords are requested through a hidden prompt and are
never placed in command arguments or shell history.

Configuration environment variables:
  ROUNDCUBE_OPENBAO_APPROLE_ID             OpenBao AppRole role_id
  ROUNDCUBE_OPENBAO_APPROLE_SECRET         OpenBao AppRole secret_id
  ROUNDCUBE_OPENBAO_APPROLE_MOUNT          default: approle
  ROUNDCUBE_OIDC_PROVISIONING_TOKEN_FILE  default: /root/.secrets/openbao-provisioning-token
  ROUNDCUBE_OIDC_ISSUER                   default: https://auth.sizestation.com/application/o/roundcube/
  ROUNDCUBE_OPENBAO_ADDRESS               default: https://bao.sizestation.cloud
  ROUNDCUBE_OIDC_ADMIN_VERSION            default: 1.0.0-rc.15
  ROUNDCUBE_OIDC_ADMIN_FORMAT             human or json; default: human
USAGE
}

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

require_argument() {
    local value="${1:-}"
    local label="$2"
    [[ -n "$value" ]] || die "${label} is required"
}

preflight() {
    command -v docker >/dev/null 2>&1 || die 'docker is not installed'
    command -v sha256sum >/dev/null 2>&1 || die 'sha256sum is not installed'
    if [[ -n "$APPROLE_ID" || -n "$APPROLE_SECRET" ]]; then
        [[ -n "$APPROLE_ID" && -n "$APPROLE_SECRET" ]] \
            || die 'set both ROUNDCUBE_OPENBAO_APPROLE_ID and ROUNDCUBE_OPENBAO_APPROLE_SECRET'
    else
        [[ -r "$TOKEN_FILE" ]] || die \
            "set AppRole credentials or provide a readable provisioning token: ${TOKEN_FILE}"
    fi
    docker volume inspect "$DB_VOLUME" >/dev/null 2>&1 || die "Docker volume not found: ${DB_VOLUME}"
    docker volume inspect "$SECRETS_VOLUME" >/dev/null 2>&1 || die "Docker volume not found: ${SECRETS_VOLUME}"
    docker network inspect "$NETWORK" >/dev/null 2>&1 || die "Docker network not found: ${NETWORK}"
}

docker_command() {
    local auth_arguments=()
    if [[ -n "$APPROLE_ID" ]]; then
        export ROUNDCUBE_OPENBAO_PROVISIONING_ROLE_ID="$APPROLE_ID"
        export ROUNDCUBE_OPENBAO_PROVISIONING_SECRET_ID="$APPROLE_SECRET"
        export ROUNDCUBE_OPENBAO_PROVISIONING_APPROLE_MOUNT="$APPROLE_MOUNT"
        auth_arguments=(
            -e ROUNDCUBE_OPENBAO_PROVISIONING_ROLE_ID
            -e ROUNDCUBE_OPENBAO_PROVISIONING_SECRET_ID
            -e ROUNDCUBE_OPENBAO_PROVISIONING_APPROLE_MOUNT
        )
    else
        auth_arguments=(
            --mount "type=bind,src=${TOKEN_FILE},dst=/run/admin-secrets/openbao-provisioning-token,readonly"
            -e ROUNDCUBE_OPENBAO_PROVISIONING_TOKEN_FILE=/run/admin-secrets/openbao-provisioning-token
        )
    fi

    docker run --rm -i \
        --network "$NETWORK" \
        --mount "source=${DB_VOLUME},target=/var/roundcube/db" \
        --mount "source=${SECRETS_VOLUME},target=/run/secrets,readonly" \
        "${auth_arguments[@]}" \
        -e ROUNDCUBEMAIL_DB_TYPE=sqlite \
        -e "ROUNDCUBEMAIL_COMPOSER_PLUGINS=sizestation/roundcube-oidc-suite:${VERSION}" \
        -e ROUNDCUBEMAIL_PLUGINS=roundcube_oidc_suite \
        -e "ROUNDCUBE_OIDC_ISSUER=${ISSUER}" \
        -e "ROUNDCUBE_OPENBAO_ADDRESS=${OPENBAO_ADDRESS}" \
        -e ROUNDCUBE_OPENBAO_TOKEN_FILE=/run/secrets/openbao-token \
        --entrypoint /docker-entrypoint.sh \
        "$IMAGE" \
        bin/../plugins/roundcube_oidc_suite/bin/sizestation-oidc \
        "$@" --format "$FORMAT"
}

credential_reference() {
    local sub="$1"
    local mailbox="$2"
    local digest
    digest="$(printf '%s\0%s' "$sub" "$mailbox" | sha256sum)"
    printf 'managed/%s\n' "${digest%% *}"
}

password_command() {
    local password=''
    read -rsp 'Purelymail password: ' password
    printf '\n' >&2
    [[ -n "$password" ]] || die 'password cannot be empty'
    printf '%s' "$password" | docker_command "$@" --password-stdin
    unset password
}

confirm() {
    local prompt="$1"
    local answer=''
    read -rp "${prompt} [y/N] " answer
    [[ "$answer" == 'y' || "$answer" == 'Y' || "$answer" == 'yes' || "$answer" == 'YES' ]]
}

dry_run=()
if [[ "${1:-}" == '--dry-run' ]]; then
    dry_run=(--dry-run)
    shift
fi

command_name="${1:-help}"
if [[ $# -gt 0 ]]; then
    shift
fi

if [[ "$command_name" == 'help' || "$command_name" == '--help' || "$command_name" == '-h' ]]; then
    usage
    exit 0
fi

preflight

case "$command_name" in
    provision|add-email)
        sub="${1:-}"
        mailbox="${2:-}"
        label="${3:-}"
        require_argument "$sub" 'SUB'
        require_argument "$mailbox" 'MAILBOX'
        arguments=(
            provision
            --issuer "$ISSUER"
            --external-user-id "$sub"
            --mailbox "$mailbox"
            --credential-reference "$(credential_reference "$sub" "$mailbox")"
            "${dry_run[@]}"
        )
        if [[ -n "$label" ]]; then
            arguments+=(--label "$label")
        fi
        if [[ "$command_name" == 'provision' ]]; then
            arguments+=(--anchor --preferred)
        fi
        password_command "${arguments[@]}"
        ;;
    users)
        docker_command principal:list
        ;;
    user)
        require_argument "${1:-}" 'PRINCIPAL_ID'
        docker_command principal:show --principal-id "$1"
        ;;
    emails)
        if [[ -n "${1:-}" ]]; then
            docker_command assignment:list --principal-id "$1"
        else
            docker_command assignment:list
        fi
        ;;
    email)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        docker_command assignment:show --assignment-id "$1"
        ;;
    rotate)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        password_command assignment:rotate-secret --assignment-id "$1" "${dry_run[@]}"
        ;;
    validate)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        docker_command assignment:validate --assignment-id "$1" "${dry_run[@]}"
        ;;
    prefer)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        docker_command assignment:set-preferred --assignment-id "$1" "${dry_run[@]}"
        ;;
    clear-preferred)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        docker_command assignment:clear-preferred --assignment-id "$1" "${dry_run[@]}"
        ;;
    enable-email|disable-email)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        operation="assignment:${command_name%-email}"
        docker_command "$operation" --assignment-id "$1" "${dry_run[@]}"
        ;;
    remove-email)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        if [[ ${#dry_run[@]} -eq 0 ]] && ! confirm 'Retire this assignment? Its OpenBao credential will be retained.'; then
            die 'removal cancelled'
        fi
        docker_command assignment:remove --assignment-id "$1" "${dry_run[@]}"
        ;;
    purge-email)
        require_argument "${1:-}" 'ASSIGNMENT_ID'
        if [[ ${#dry_run[@]} -eq 0 ]] && ! confirm 'Permanently retire this assignment and delete its OpenBao credential?'; then
            die 'removal cancelled'
        fi
        docker_command assignment:remove --assignment-id "$1" --delete-secret "${dry_run[@]}"
        ;;
    enable-user|disable-user)
        require_argument "${1:-}" 'PRINCIPAL_ID'
        operation="principal:${command_name%-user}"
        docker_command "$operation" --principal-id "$1" "${dry_run[@]}"
        ;;
    reconcile-user)
        require_argument "${1:-}" 'PRINCIPAL_ID'
        docker_command reconcile:user --principal-id "$1" "${dry_run[@]}"
        ;;
    reconcile-all)
        docker_command reconcile:all "${dry_run[@]}"
        ;;
    audit)
        if [[ -n "${1:-}" ]]; then
            docker_command audit:list --principal-id "$1"
        else
            docker_command audit:list
        fi
        ;;
    raw)
        [[ $# -gt 0 ]] || die 'raw requires CLI arguments'
        docker_command "$@"
        ;;
    *)
        usage >&2
        die "unknown command: ${command_name}"
        ;;
esac
