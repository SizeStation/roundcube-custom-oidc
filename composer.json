{
    "name": "sizestation/roundcube-oidc-suite",
    "description": "Single-package Authentik OIDC and OpenBao-managed multi-account support for Roundcube",
    "type": "roundcube-plugin",
    "license": "AGPL-3.0-or-later",
    "require": {
        "firebase/php-jwt": "^7.1",
        "php": ">=8.2",
        "roundcube/plugin-installer": "^0.3.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "SizeStation\\Roundcube\\Credentials\\": "packages/credentials/src/",
            "SizeStation\\Roundcube\\Oidc\\": "plugins/sizestation_oidc/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SizeStation\\Roundcube\\Tests\\Oidc\\": "plugins/sizestation_oidc/tests/",
            "SizeStation\\Roundcube\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "roundcube/plugin-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "roundcube": {
            "min-version": "1.7",
            "post-install-script": "./bin/install-roundcube-oidc.php",
            "post-update-script": "./bin/install-roundcube-oidc.php",
            "post-uninstall-script": "./bin/uninstall-roundcube-oidc.php"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
