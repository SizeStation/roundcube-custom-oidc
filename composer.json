{
    "name": "sizestation/roundcube-oidc-distribution",
    "description": "Authentik OIDC and OpenBao-managed mailbox support for Roundcube",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "require": {
        "firebase/php-jwt": "^7.1",
        "php": ">=8.2",
        "sizestation/roundcube-credentials": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/credentials",
            "options": {
                "symlink": false
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "SizeStation\\Roundcube\\Oidc\\": "plugins/sizestation_oidc/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SizeStation\\Roundcube\\Tests\\Oidc\\": "plugins/sizestation_oidc/tests/",
            "SizeStation\\Roundcube\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": false,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
