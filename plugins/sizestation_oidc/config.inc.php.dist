<?php

// This file intentionally contains no secrets. Sensitive values are read from
// files rendered into the runtime secret volume.
$readRequiredFile = static function (string $path): string {
    $value = @file_get_contents($path);
    if (!is_string($value) || trim($value) === '') {
        throw new RuntimeException("Required OIDC configuration file is unavailable: {$path}");
    }

    return trim($value);
};
$oidcEnvOrFile = static function (string $name, string $default = '') use ($readRequiredFile): string {
    $value = trim((string) getenv($name));
    $file = trim((string) getenv($name . '_FILE'));
    if ($value !== '' && $file !== '') {
        throw new RuntimeException("Set either {$name} or {$name}_FILE, not both");
    }

    return $file !== '' ? $readRequiredFile($file) : ($value !== '' ? $value : $default);
};
$oidcEnvList = static function (string $name, array $default) use ($oidcEnvOrFile): array {
    $value = $oidcEnvOrFile($name);
    if ($value === '') {
        return $default;
    }
    $items = preg_split('/[\s,]+/', $value, -1, PREG_SPLIT_NO_EMPTY);

    return is_array($items) ? array_values(array_unique($items)) : $default;
};
$config['sizestation_oidc.enabled'] = false;
$config['sizestation_oidc.issuer'] = $oidcEnvOrFile(
    'ROUNDCUBE_OIDC_ISSUER',
    'https://auth.sizestation.cloud/application/o/roundcube/',
);
$config['sizestation_oidc.client_id'] = $oidcEnvOrFile('ROUNDCUBE_OIDC_CLIENT_ID');
$config['sizestation_oidc.client_secret_file'] = $oidcEnvOrFile(
    'ROUNDCUBE_OIDC_CLIENT_SECRET_FILE',
    '/run/app-secrets/oidc-client-secret',
);
$config['sizestation_oidc.redirect_uri'] = $oidcEnvOrFile(
    'ROUNDCUBE_OIDC_REDIRECT_URI',
    'https://mail.sizestation.cloud/?_task=login&_action=plugin.sizestation_oidc.callback',
);
$config['sizestation_oidc.post_logout_redirect_uri'] = $oidcEnvOrFile(
    'ROUNDCUBE_OIDC_POST_LOGOUT_REDIRECT_URI',
    'https://mail.sizestation.cloud/',
);
$config['sizestation_oidc.scopes'] = $oidcEnvList(
    'ROUNDCUBE_OIDC_SCOPES',
    ['openid', 'profile', 'email'],
);
$config['sizestation_oidc.external_user_id_claim'] = $oidcEnvOrFile(
    'ROUNDCUBE_OIDC_EXTERNAL_USER_ID_CLAIM',
    'sub',
);
$config['sizestation_oidc.allowed_algorithms'] = ['RS256'];
$config['sizestation_oidc.allowed_groups'] = [];
$config['sizestation_oidc.groups_claim'] = 'groups';
$config['sizestation_oidc.hide_password_form'] = true;
$config['sizestation_oidc.source_url'] =
    'https://github.com/SizeStation/roundcube-custom-oidc';
$config['sizestation_oidc.clock_tolerance_seconds'] = 60;
$config['sizestation_oidc.connect_timeout_seconds'] = 2;
$config['sizestation_oidc.request_timeout_seconds'] = 5;

$config['sizestation_oidc.imap_host'] = 'ssl://imap.purelymail.com:993';
$config['sizestation_oidc.openbao_address'] = 'https://openbao.sizestation.internal:8200';
$config['sizestation_oidc.openbao_token_file'] = '/run/app-secrets/openbao-token';
$config['sizestation_oidc.openbao_kv_mount'] = 'kv';
$config['sizestation_oidc.openbao_base_path'] = 'roundcube/mailboxes';
$config['sizestation_oidc.openbao_ca_file'] = '/run/app-secrets/openbao-ca.pem';
$config['sizestation_oidc.openbao_connect_timeout_seconds'] = 2;
$config['sizestation_oidc.openbao_request_timeout_seconds'] = 5;

// Provisioning authentication is only supplied to an administrative CLI task,
// never to the long-running Roundcube web service. AppRole is preferred; a
// pre-issued token file remains supported for compatibility.
$config['sizestation_oidc.openbao_provisioning_token_file'] =
    '/run/admin-secrets/openbao-provisioning-token';
$config['sizestation_oidc.openbao_provisioning_role_id'] = $oidcEnvOrFile(
    'ROUNDCUBE_OPENBAO_PROVISIONING_ROLE_ID',
);
$config['sizestation_oidc.openbao_provisioning_secret_id'] = $oidcEnvOrFile(
    'ROUNDCUBE_OPENBAO_PROVISIONING_SECRET_ID',
);
$config['sizestation_oidc.openbao_provisioning_approle_mount'] = $oidcEnvOrFile(
    'ROUNDCUBE_OPENBAO_PROVISIONING_APPROLE_MOUNT',
    'approle',
);
$config['sizestation_oidc.validate_imap_on_provision'] = true;
$config['sizestation_oidc.validate_smtp_on_provision'] = true;
$config['sizestation_oidc.validation_imap_endpoint'] = 'ssl://imap.purelymail.com:993';
$config['sizestation_oidc.validation_smtp_endpoint'] = 'tcp://smtp.purelymail.com:587';
$config['sizestation_oidc.validation_timeout_seconds'] = 10;
