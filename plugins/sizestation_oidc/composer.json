{
    "name": "sizestation/roundcube-oidc",
    "description": "Authentik OIDC and managed mailbox assignments for Roundcube",
    "type": "roundcube-plugin",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.2",
        "roundcube/plugin-installer": ">=0.3.0",
        "sizestation/roundcube-credentials": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "SizeStation\\Roundcube\\Oidc\\": "src/"
        }
    },
    "extra": {
        "roundcube": {
            "min-version": "1.7",
            "sql-dir": "SQL"
        }
    }
}
